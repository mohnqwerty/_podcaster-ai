######################################################################
# podcaster-ai — environment template
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to git. Never bake real keys into the image.
######################################################################

############################
# LLM PROVIDER
############################
# Which OpenAI-compatible backend to use: deepseek | openrouter | kimi | qwen | gemini | groq
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Model name. Examples per provider:
#   deepseek   -> deepseek-chat
#   openrouter -> deepseek/deepseek-chat or moonshotai/kimi-k2
#   kimi       -> moonshot-v1-32k or kimi-k2-0711-preview
#   qwen       -> qwen-plus or qwen2.5-72b-instruct
#   gemini     -> gemini-2.5-flash or gemini-2.5-pro
#   groq       -> llama-3.3-70b-versatile or llama-3.1-8b-instant
# Optional: override base URL (rarely needed).
# LLM_BASE_URL=

# Provider keys (only set the one matching LLM_PROVIDER)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
OPENROUTER_API_KEY="your-openrouter-api-key-here"
MOONSHOT_API_KEY="your-moonshot-api-key-here"
# Some users prefer api.moonshot.ai over the .cn endpoint; override if needed.
# MOONSHOT_API_BASE=https://api.moonshot.ai/v1
DASHSCOPE_API_KEY=""
# Google Gemini (uses the OpenAI-compatible endpoint)
GEMINI_API_KEY="your-gemini-api-key-here"
# Groq (very fast inference; uses the OpenAI-compatible endpoint at api.groq.com/openai/v1)
GROQ_API_KEY="your-groq-api-key-here"

# Tunables
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=4

############################
# TTS PROVIDER
############################
# edge | elevenlabs | sarvam
TTS_PROVIDER=edge

# edge-tts voices (free, no key required). Override if you prefer different voices.
MAYA_VOICE=en-US-AriaNeural
ARJUN_VOICE=en-US-GuyNeural

# ElevenLabs (only required if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY="your-elevenlabs-api-key-here"
ELEVENLABS_MAYA_VOICE_ID="your-maya-voice-id-here"
ELEVENLABS_ARJUN_VOICE_ID="your-arjun-voice-id-here"
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Sarvam AI TTS (Indian voices, requires free API key from https://dashboard.sarvam.ai)
# SARVAM_API_KEY="your-sarvam-api-key-here"
# SARVAM_MODEL=bulbul:v3
# SARVAM_SPEAKER_MAYA=neha
# SARVAM_SPEAKER_ARJUN=shubh
# SARVAM_PACE=1.0
# SARVAM_TEMPERATURE=0.6

############################
# TELEGRAM DELIVERY
############################
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
TELEGRAM_CHAT_ID="your-telegram-chat-id-here"

############################
# SOURCES
############################
# Comma-separated list of vendor advisory RSS feed URLs (optional).
VENDOR_RSS_FEEDS=
# Comma-separated list of YouTube channel IDs to pull recent transcripts from (optional).
# Defaults include Black Hat (UCS90qS2YOo6HQC3uH9_95MA) and DEF CON (UC6Om9kAkl32dWlDS_lX9W3Q).
YOUTUBE_CHANNEL_IDS=UCS90qS2YOo6HQC3uH9_95MA,UC6Om9kAkl32dWlDS_lX9W3Q
# Lookback window in days for YouTube transcripts.
YOUTUBE_LOOKBACK_DAYS=14
# Minimum CVSS score for NVD recent CVEs.
NVD_MIN_CVSS=6.5
# Lookback window in hours for NVD recent CVEs.
NVD_LOOKBACK_HOURS=72
# Maximum items per source after ranking (keeps the brief tight).
MAX_ITEMS_PER_SOURCE=8
# Hard cap on total items fed into the research stage.
MAX_TOTAL_ITEMS=40

############################
# MASTODON (Tier 3 leads — cross-check before asserting as fact)
############################
# Base URL of the Mastodon-compatible instance. Default: infosec.exchange.
MASTODON_BASE_URL=https://infosec.exchange
# Personal access token. Required to enable the source; if empty, the
# Mastodon fetcher returns no items (no errors raised).
# Generate one at: <instance> -> Preferences -> Development -> New application,
# scopes: read:statuses read:lists read:accounts read:bookmarks read:favourites
MASTODON_ACCESS_TOKEN="your-mastodon-access-token-here"
# Comma-separated hashtags (no leading #) to pull recent statuses for.
MASTODON_HASHTAGS=infosec,cve,bugbounty,0day,threatintel
# Whether to include the home timeline (true/false).
MASTODON_INCLUDE_HOME=true
# Whether to include bookmarked statuses (true/false).
MASTODON_INCLUDE_BOOKMARKS=true
# Time window in hours; older statuses are filtered out.
MASTODON_HOURS=48

############################
# PODCAST METADATA
############################
PODCAST_TITLE=Daily Recon
HOST_MAYA_NAME=Maya
HOST_ARJUN_NAME=Arjun
TIMEZONE=Asia/Kolkata

############################
# OUTPUT / RUNTIME
############################
# Where artifacts are written inside the container (also bind-mounted to ./out).
OUTPUT_DIR=/app/out
# Persistent dashboard data (sqlite DB + episodes/) lives here. If unset, falls
# back to OUTPUT_DIR. In Docker this is bind-mounted to ./data on the host.
DATA_DIR=/app/data
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

############################
# WEB DASHBOARD (PART B)
############################
# The dashboard binds to this host:port. Always 127.0.0.1 unless you run it
# in Docker (where 0.0.0.0 is fine because the container's port is only
# exposed to a reverse proxy on the host).
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
# REQUIRED to start the dashboard. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Set to false ONLY for local plain-HTTP dev. Production: keep true.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_NAME=podcaster_session
CSRF_COOKIE_NAME=podcaster_csrf
# Optional one-time admin bootstrap. If both are set on first start, the user
# is created (with role=admin). Subsequent starts are no-ops. Once the admin
# exists, unset these and restart so they don't sit on disk.
# Optional override for the SQLAlchemy database URL. Default: sqlite under DATA_DIR.
# DATABASE_URL=sqlite+aiosqlite:////app/data/podcaster.db
SESSION_SECRET="generate-with-python3-c-import-secrets-print-secrets-token-urlsafe-48"
BOOTSTRAP_ADMIN_PASSWORD="generate-with-python3-c-import-secrets-print-secrets-token-urlsafe-16"
BOOTSTRAP_ADMIN_USER=admin
